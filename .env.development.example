# ─── Development / Pre-production ───────────────────────────────────────────
# Copy to .env.local for local dev (Vite loads .env.local automatically)
#
# OTP email disabled: new accounts sign in immediately.
# Make sure Supabase Dashboard → Auth → Settings has "Email Confirmations" OFF.
# Also run supabase/toggle_otp_email.sql (development block) in SQL Editor.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Controls OTP email requirement (see src/config/auth-mode.ts)
VITE_APP_MODE=development
