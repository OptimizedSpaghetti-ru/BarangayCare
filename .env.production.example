# ─── Production ──────────────────────────────────────────────────────────────
# Set these as environment variables in Vercel / your hosting provider.
# Do NOT commit actual keys to git.
#
# OTP email enabled: users must verify their email before logging in.
# Make sure Supabase Dashboard → Auth → Settings has "Email Confirmations" ON.
# Also run supabase/toggle_otp_email.sql (production block) in SQL Editor.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Controls OTP email requirement (see src/config/auth-mode.ts)
VITE_APP_MODE=production
